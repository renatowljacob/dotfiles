#!/bin/sh

# 1 = left click
# 4 = scroll up
# 5 = scroll down

message="left click -> mute

scroll up/down -> increase/decrease volume"

case $BLOCK_BUTTON in
1) volume mute ;;
4) volume up ;;
5) volume down ;;
*) dunstify -i "${XDG_DATA_HOME}/icons/dunst/circle-exclamation.svg" -a "dusk" "${message}" ;;
esac
