#!/bin/sh

updates=$(
    {
        checkupdates
        paru -Qu
    } | wc -l
)

if [ "${updates}" -ge 10 ]; then
    if [ "${1}" = "dusk" ]; then
        bgcolor='#24283b'
        accentcolor='#9ECE6A'
        style="^c${accentcolor}^^r00,00,14,h^^f14^^b${accentcolor}^^c${bgcolor}^ď‚« ^c${accentcolor}^^r00,00,6,h^^d^^f22^^c${accentcolor}^"

        printf '%s' "${style}${updates}^f8^"
    else
        printf '%s' "${updates}"
    fi
fi
