#!/bin/sh

# 1 = left click

message="left click -> show updates"

get_packages()
{
    dunstrc="${XDG_CONFIG_HOME:-$HOME/.config}/dunst/dunstrc"
    lines="$(wc -l "${cachefile}")"
    max_height="$(
        sed -n 's/^ *height.* \([[:digit:]]\+\).*/\1/p' "${dunstrc}" \
            | tr '\n' ' ' \
            | cut -d ' ' -f 1
    )"
    packages=

    # Truncate if there are more packages than dunst's maximum height
    max_lines=30
    if [ "${lines%% *}" -gt $((max_height / max_lines)) ]; then
        packages="$(printf '%s\n%s' "$(sed -n '1,25p' "${cachefile}")" '...')"
    fi

    printf '%b' "${packages:-$(cat "${cachefile}")}"
}

print_packages()
{
    cachefile="${XDG_RUNTIME_DIR:-/tmp}/dusk-updatesclick"

    if updates="$(checkupdates -c --nocolor)" || [ ! -s "${cachefile}" ]; then
        if [ -n "${updates}" ]; then
            printf '%s' "${updates:-$(checkupdates --nocolor)}" \
                | sed 's/\([[:alnum:]]*\) .*/\1/' > "${cachefile}"
        fi

        dunstify -a "Updates" "$(get_packages)"
    else
        : > "${cachefile}" && dunstify -a "${1}" "No updates available"
    fi

}

if ps -C dusk; then
    case $BLOCK_BUTTON in
    1)
        print_packages dusk
        duskc --ignore-reply run_command setstatus 5 "$(statusbar-updates)" &
        ;;
    *)
        dunstify -i "${XDG_DATA_HOME}/icons/dunst/circle-exclamation.svg" -a "Updates" "${message}"
        ;;
    esac
elif ps -C mango; then
    print_packages mango
fi
